<view class="container data-v-0f00adf4"><block wx:if="{{$root.g0===0}}"><view class="empty data-v-0f00adf4"><text class="data-v-0f00adf4">购物车为空</text></view></block><block wx:else><view class="data-v-0f00adf4"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="index" wx:key="dishId"><view class="cart-item data-v-0f00adf4"><block wx:if="{{item.$orig.image}}"><image class="item-img data-v-0f00adf4" src="{{item.m0}}" mode="aspectFill"></image></block><block wx:else><view class="item-img placeholder data-v-0f00adf4">暂无图</view></block><view class="item-info data-v-0f00adf4"><text class="item-name data-v-0f00adf4">{{item.$orig.dishName}}</text><text class="item-price data-v-0f00adf4">{{"¥"+item.g1}}</text></view><view class="quantity-ctrl data-v-0f00adf4"><view data-event-opts="{{[['tap',[['changeQty',[index,-1]]]]]}}" class="qty-btn data-v-0f00adf4" bindtap="__e">-</view><text class="qty-num data-v-0f00adf4">{{item.$orig.quantity}}</text><view data-event-opts="{{[['tap',[['changeQty',[index,1]]]]]}}" class="qty-btn data-v-0f00adf4" bindtap="__e">+</view></view></view></block><view class="table-input data-v-0f00adf4"><text class="data-v-0f00adf4">桌号：</text><input placeholder="请输入桌号" type="text" data-event-opts="{{[['input',[['__set_model',['','tableNo','$event',[]]]]]]}}" value="{{tableNo}}" bindinput="__e" class="data-v-0f00adf4"/></view><view class="table-input data-v-0f00adf4"><text class="data-v-0f00adf4">备注：</text><input placeholder="如：不要辣、少盐等" type="text" data-event-opts="{{[['input',[['__set_model',['','remark','$event',[]]]]]]}}" value="{{remark}}" bindinput="__e" class="data-v-0f00adf4"/></view><view class="bottom-bar data-v-0f00adf4"><view class="total data-v-0f00adf4">合计：<text class="total-price data-v-0f00adf4">{{"¥"+$root.g2}}</text></view><view data-event-opts="{{[['tap',[['submitOrder',['$event']]]]]}}" class="submit-btn data-v-0f00adf4" bindtap="__e">提交订单</view></view></view></block></view>